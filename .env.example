# MotoGram — Variáveis de Ambiente
# Copiar para .env e preencher com os valores reais
# NUNCA commitar o ficheiro .env

# Django
SECRET_KEY=gera-uma-chave-forte-aqui
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Base de dados
DATABASE_URL=postgresql://postgres:password@host:5432/postgres

# Redis (Upstash)
REDIS_URL=redis://default:password@xxxx.upstash.io:6379

# Telegram
TELEGRAM_TOKEN=1234567890:ABCdef-seu-token-aqui
TELEGRAM_WEBHOOK_URL=https://motogram.app/api/bot/update/
# Secret interno para comunicação bot↔backend (gera com: python -c "import secrets; print(secrets.token_hex(32))")
BOT_SECRET=

# Mercado Pago
MP_ACCESS_TOKEN=
MP_WEBHOOK_SECRET=

# App
BACKEND_URL=http://localhost:8000
SITE_URL=http://localhost:8000
CSRF_TRUSTED_ORIGINS=http://localhost:8000
PRECO_ASSINATURA_MENSAL=6900
# Prefixo opaco da rota do painel admin (default: admin_mg). Em produção usar valor opaco.
ADMIN_SECRET_PATH=admin_mg

# HERE Maps (geocoding + autocomplete — 250k transações/mês grátis)
# Obter em: https://platform.here.com → projecto → REST → API Key
HERE_API_KEY=

# (Opcional) SMS para link de activação
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# (Opcional) Monitoramento de erros
SENTRY_DSN=
